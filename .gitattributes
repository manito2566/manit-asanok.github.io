# Normalize line endings on commit, keep native in working dir on Windows
* text=auto

# Force LF for web/script files (deployed as-is)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
